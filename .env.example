# Copy to .env for local development
# In GitHub Actions, set these as repository/environment secrets

# Required
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — Telegram notifications
# Create bot: @BotFather on Telegram, then /newbot
# Get your chat ID: message @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Neuroscience Digest (neuro-digest skill)
XAI_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Webhook auth (for /api/setup-webhook)
CRON_SECRET=
